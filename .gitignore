# Dependencies
node_modules/  # Installed npm packages - don't commit these

# Playwright test artifacts
/test-results/     # Test results and screenshots from failed tests
/playwright-report/  # HTML test reports generated by Playwright
/blob-report/      # Binary test reports
/playwright/.cache/  # Playwright's internal cache
/playwright/.auth/   # Saved authentication states

# VSCode settings
.vscode/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Optional Playwright artifacts
/.local-browsers/
.playwright/

# Build output
/dist/
/build/
